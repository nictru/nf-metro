%%metro title: BT Exit Into LR
%%metro style: dark
%%metro line: a | A | #e63946

%%metro grid: work | 0,0
%%metro grid: out_sec | 1,0

graph LR
    subgraph work [Work]
        %%metro direction: BT
        %%metro exit: right | a
        w1[Ingest]
