---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import { getCollection } from "astro:content";
import { base } from "../../site";

const entries = await getCollection("gallery");

// Group entries by category, preserving insertion order.
const byCategory = new Map<string, typeof entries>();
for (const entry of entries) {
  const cat = entry.data.category;
  if (!byCategory.has(cat)) byCategory.set(cat, []);
  byCategory.get(cat)!.push(entry);
}
---

<StarlightPage
  frontmatter={{
    title: "Gallery",
    description:
      "Rendered examples covering fan-outs, folds, diamonds, and realistic bioinformatics workflows.",
    template: "doc",
    tableOfContents: false,
    pagefind: true,
    prev: false,
    next: false,
  }}
>
  <p>
    Examples covering the full range of layout patterns. Click any entry to see
    the rendered map, Mermaid source, and CLI command.
  </p>

  {
    Array.from(byCategory.entries()).map(([category, items]) => (
      <section class="nfm-gallery-section">
        <h2>{category}</h2>
        <ul class="nfm-gallery-grid">
          {items.map((entry) => (
            <li>
              <a href={`${base}gallery/${entry.id}/`}>
                <strong>{entry.data.title}</strong>
                <span>{entry.data.description}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))
  }
</StarlightPage>

<style>
  .nfm-gallery-section {
    margin-block: 2rem;
  }

  .nfm-gallery-section h2 {
    font-size: var(--sl-text-h4);
    border-bottom: 1px solid var(--sl-color-hairline);
    padding-bottom: 0.4rem;
    margin-bottom: 1rem;
  }

  .nfm-gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(17rem, 1fr));
    gap: 0.75rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .nfm-gallery-grid li a {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 0.75rem 1rem;
    border: 1px solid var(--sl-color-hairline);
    border-radius: 6px;
    text-decoration: none;
    color: inherit;
    background: var(--sl-color-bg);
    transition: border-color 0.12s ease, background 0.12s ease;
  }

  .nfm-gallery-grid li a:hover {
    border-color: var(--sl-color-accent);
    background: var(--sl-color-bg-nav);
  }

  .nfm-gallery-grid li a strong {
    font-size: 0.875rem;
    color: var(--sl-color-text-accent);
    font-family: var(--sl-font-mono, monospace);
  }

  .nfm-gallery-grid li a span {
    font-size: 0.8rem;
    color: var(--sl-color-gray-3);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
