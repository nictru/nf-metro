---
import { Code } from "@astrojs/starlight/components";
import { renderMetro } from "../plugins/metro.mjs";
import ZoomableSVG from "@components/ZoomableSVG.astro";

interface Props {
  src: string;
  title?: string;
  showCode?: boolean;
}

const { src, title, showCode = true } = Astro.props;
const svg = renderMetro(src);
---

{showCode && <Code code={src} lang="metro" title={title} />}
<ZoomableSVG>
  <Fragment set:html={svg} />
</ZoomableSVG>
