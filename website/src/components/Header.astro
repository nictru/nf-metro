---
import config from "virtual:starlight/user-config";
import Search from "virtual:starlight/components/Search";
import SocialIcons from "virtual:starlight/components/SocialIcons";
import ThemeSelect from "virtual:starlight/components/ThemeSelect";
import Logo from "../assets/logo.svg";
import { base, REPO, GITHUB_URL } from "../site";

const { siteTitleHref } = Astro.locals.starlightRoute;

const shouldRenderSearch =
  config.pagefind ||
  config.components.Search !== "@astrojs/starlight/components/Search.astro";

const links = [
  { label: "Guide", href: `${base}guide/` },
  { label: "Gallery", href: `${base}gallery/` },
  { label: "Pipelines", href: `${base}pipelines/` },
  { label: "Playground", href: `${base}playground/` },
];

// Resolve the latest GitHub release at build time (cached once per build).
const g = globalThis as {
  __nfmRelease?: Promise<{ label: string; url: string }>;
};
g.__nfmRelease ??= (async () => {
  const fallback = { label: "Releases", url: `${GITHUB_URL}/releases` };
  try {
    const headers: Record<string, string> = {
      Accept: "application/vnd.github+json",
    };
    if (process.env.GITHUB_TOKEN)
      headers.Authorization = `Bearer ${process.env.GITHUB_TOKEN}`;
    // Bounded timeout so a slow/hanging API degrades to the fallback, never stalls the build.
    const res = await fetch(
      `https://api.github.com/repos/${REPO}/releases?per_page=1`,
      {
        headers,
        signal: AbortSignal.timeout(5000),
      },
    );
    if (!res.ok) return fallback;
    const releases = (await res.json()) as Array<{
      tag_name: string;
      html_url: string;
    }>;
    if (!Array.isArray(releases) || releases.length === 0) return fallback;
    return { label: releases[0].tag_name, url: releases[0].html_url };
  } catch {
    return fallback;
  }
})();
const { label: versionLabel, url: versionUrl } = await g.__nfmRelease;
---

<div class="header nfm-header">
  <div class="title-wrapper sl-flex">
    <a
      href={siteTitleHref}
      class="site-title nfm sl-flex"
      aria-label="nf-metro home"
    >
      <Logo class="nfm-logo" />
    </a>
  </div>

  <div class="nfm-nav sl-hidden md:sl-flex print:hidden">
    <nav class="nfm-topnav" aria-label="Primary">
      {
        links.map(({ label, href }) => (
          <a class="link" href={href}>
            {label}
          </a>
        ))
      }
    </nav>
    <a class="nfm-ver" href={versionUrl}>{versionLabel}</a>
    {shouldRenderSearch && <Search />}
    <div class="sl-flex social-icons"><SocialIcons /></div>
    <ThemeSelect />
  </div>

  <div class="nfm-nav-mobile sl-flex md:sl-hidden print:hidden">
    {shouldRenderSearch && <Search />}
    <ThemeSelect />
  </div>
</div>

<style>
  @layer starlight.core {
    .header {
      display: flex;
      gap: var(--sl-nav-gap);
      justify-content: space-between;
      align-items: center;
      height: 100%;
    }
    .title-wrapper {
      overflow: clip;
      padding: 0;
      margin: 0;
      min-width: 0;
    }
    .nfm-nav,
    .nfm-nav-mobile,
    .social-icons {
      gap: 0.7rem;
      align-items: center;
    }
    .social-icons::after {
      content: "";
      height: 1.8rem;
      border-inline-end: 1px solid var(--sl-color-gray-5);
    }
  }
</style>
