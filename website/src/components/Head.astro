---
/* Emit the Degular @font-face + preload via Astro's Fonts API. `<Font>` must
   live in <head>, and Starlight only allows head *components* through an
   override - hence this thin wrapper. preload ensures the heading font is
   fetched before first paint, avoiding the page-title FOUT. */
import Default from "@astrojs/starlight/components/Head.astro";
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";
---

<Default />
<Font cssVariable="--nfm-degular" preload />
{/* SPA-style navigation: fetch + swap the DOM in place instead of a full
    reload, so clicks feel instant. Enabling <ClientRouter /> also turns on
    Astro's link prefetching (defaults to `hover`), so the next page is usually
    already cached by the time it's clicked. astro-mermaid re-runs on
    astro:after-swap, so diagrams survive navigation. */}
<ClientRouter />
{/* A swap copies the incoming document's `data-theme` (the server default,
    "dark") onto <html>, and Starlight's pre-paint theme script only runs on a
    full load, so the visitor's resolved theme is lost on client-side navigation.
    Re-resolve and re-apply it after each swap. The listener is on `document`,
    which survives swaps, so registering once holds. */}
<script is:inline>
  document.addEventListener("astro:after-swap", () => {
    const stored = localStorage.getItem("starlight-theme");
    document.documentElement.dataset.theme =
      stored === "light" || stored === "dark"
        ? stored
        : matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light";
  });
</script>
<script is:inline>
  // Sync gallery <picture> elements with Starlight's data-theme toggle.
  // CSS <source media="(prefers-color-scheme: light)"> handles OS-level preference
  // automatically. This script takes over only for manual site-level overrides.
  if (!window._nfmGalleryThemeInit) {
    window._nfmGalleryThemeInit = true;
    function _nfmSyncGallery() {
      var isLight = document.documentElement.dataset.theme === "light";
      document.querySelectorAll(".nfm-gallery-image").forEach(function (pic) {
        var source = pic.querySelector("source");
        var img = pic.querySelector("img");
        if (!img || !img.dataset.darkSrc) return;
        // Once JS has resolved the theme, it fully owns source selection so that
        // a manual dark-mode toggle isn't overridden by OS-level CSS media queries.
        source.media = "not all";
        img.src = isLight ? img.dataset.lightSrc : img.dataset.darkSrc;
      });
    }
    // Run after each page load (initial + SPA navigations via ClientRouter).
    document.addEventListener("astro:page-load", _nfmSyncGallery);
    // Run immediately when the toggle fires (data-theme mutation on <html>).
    new MutationObserver(function (mutations) {
      if (mutations.some(function (m) { return m.attributeName === "data-theme"; })) {
        _nfmSyncGallery();
      }
    }).observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["data-theme"],
    });
  }
</script>
